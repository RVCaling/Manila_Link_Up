<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@color/design_default_color_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/design_default_color_background" />

    <ImageView
        android:id="@+id/image_view_logo"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_below="@id/toolbar"
        android:layout_marginStart="60dp"
        android:src="@drawable/logo" />

    <TextView
        android:id="@+id/text_view_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbar"
        android:layout_marginStart="125dp"
        android:layout_marginTop="13dp"
        android:fontFamily="sans-serif-black"
        android:text="MNL LinkUp"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/text_view_get_started"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/image_view_logo"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:text="Let's get started."
        android:textSize="30sp" />

    <TextView
        android:id="@+id/text_view_do_today"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/text_view_get_started"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="How will you use Manila LinkUp today?" />


    <androidx.cardview.widget.CardView
        android:id="@+id/card_view_job_seeker"
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:layout_below="@id/text_view_do_today"
        android:layout_margin="28dp"
        android:layout_marginStart="32dp"
        android:backgroundTint="#455FB2"
        app:cardCornerRadius="6dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-medium"
                android:text="Job Seeker"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="45dp"
                android:layout_marginTop="9dp"
                android:fontFamily="sans-serif"
                android:text="I am looking for an opportunity"
                android:textColor="@color/white"
                android:textSize="18sp" />

        </LinearLayout>


    </androidx.cardview.widget.CardView>


    <androidx.cardview.widget.CardView
        android:id="@+id/card_view_employer"
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:layout_below="@id/card_view_job_seeker"
        android:layout_marginStart="32dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#455FB2"
        app:cardCornerRadius="6dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-medium"
                android:text="Employer"
                android:textColor="@color/white"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="45dp"
                android:layout_marginTop="9dp"
                android:fontFamily="sans-serif"
                android:text="I am looking for an employee"
                android:textColor="@color/white"
                android:textSize="18sp" />

        </LinearLayout>


    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/text_view_login_sign_up_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/card_view_employer"
        android:layout_marginStart="90dp"
        android:layout_marginTop="100dp"
        android:fontFamily="sans-serif-medium"
        android:text="Already have an Account? Try to"  />

    <TextView
        android:id="@+id/text_view_back_log_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/card_view_employer"
        android:layout_marginStart="3dp"
        android:layout_marginTop="100dp"
        android:layout_toEndOf="@id/text_view_login_sign_up_account"
        android:fontFamily="sans-serif-medium"
        android:text="Log in."
        android:textColor="#0D47A1" />

</RelativeLayout>