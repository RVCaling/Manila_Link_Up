<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/jobCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:layout_marginVertical="6dp"
    android:elevation="14dp"
    app:cardElevation="6dp"
    app:cardMaxElevation="12dp"
    app:cardCornerRadius="20dp"
    app:cardUseCompatPadding="false"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:id="@+id/cardBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@drawable/card_bg_selector">

        <!-- Job Title -->
        <TextView
            android:id="@+id/jobTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Events/Catering Helper"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <!-- Company -->
        <TextView
            android:id="@+id/companyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eng Bee Tin"
            android:layout_below="@id/jobTitle"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            android:textColor="#555555"/>

        <!-- Location with icon -->
        <LinearLayout
            android:id="@+id/locationLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/companyName"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_dialog_map"
                app:tint="#D32F2F"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/jobLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Binondo, Manila"
                android:textSize="13sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <!-- Salary with icon -->
        <LinearLayout
            android:id="@+id/salaryLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_below="@id/locationLayout"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:layout_marginEnd="4dp"
                app:tint="#2E7D32" />

            <TextView
                android:id="@+id/jobSalary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱700 / Day"
                android:textSize="13sp"
                android:textColor="#2E7D32"/>
        </LinearLayout>

        <!-- Schedule / Time with icon -->
        <LinearLayout
            android:id="@+id/scheduleLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_below="@id/salaryLayout"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:layout_marginEnd="4dp"
                app:tint="#1976D2" />

            <TextView
                android:id="@+id/jobSchedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="March 30, 2026"
                android:textSize="13sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <!-- Save Button -->

        <ImageButton
            android:id="@+id/saveJob"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="80dp"
            android:layout_marginEnd="0dp"
            android:background="@null"
            android:src="@android:drawable/ic_menu_save"
            app:tint="#0D47A1" />

        <ImageButton
            android:id="@+id/removeJob"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="0dp"
            android:layout_marginEnd="5dp"
            android:background="@null"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#B00020" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>