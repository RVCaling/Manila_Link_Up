<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/design_default_color_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/design_default_color_background" />

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_below="@id/toolbar"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:padding="9dp"
            android:scaleType="centerCrop"
            android:src="@drawable/insert_photo" />

        <TextView
            android:id="@+id/uploadproftext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/profileImage"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="5dp"
            android:text="Upload Profile Photo"
            android:textSize="14sp" />

        <!-- Upload Clearance -->
        <TextView
            android:id="@+id/uploadClearancetext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadproftext"
            android:layout_marginTop="30dp"
            android:text="Upload Clearance"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="25dp"/>

        <TextView
            android:id="@+id/uploadClearanceExtaxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadClearancetext"
            android:text="(Ex. NBI, Police, \nBarangay Clearance)"
            android:textSize="14sp"
            android:layout_marginStart="25dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadClearancebtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/uploadClearancetext"
            android:text="Upload"
            android:textStyle="bold"
            app:backgroundTint="#0D47A1"
            app:icon="@drawable/baseline_arrow_upward_24"
            android:layout_marginEnd="25dp"/>

        <!-- Upload ID -->
        <TextView
            android:id="@+id/uploadvalidIDtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadClearanceExtaxt"
            android:layout_marginTop="30dp"
            android:text="Upload Valid ID"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="25dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadIDbtn"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/uploadvalidIDtext"
            android:text="Upload"
            android:textStyle="bold"
            app:backgroundTint="#0D47A1"
            app:icon="@drawable/baseline_arrow_upward_24"
            android:layout_marginEnd="25dp"/>

        <!-- Preferred Location -->
        <TextView
            android:id="@+id/pref_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadvalidIDtext"
            android:layout_marginTop="30dp"
            android:text="Preferred Location"
            android:textStyle="bold"
            android:layout_marginStart="25dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/pref_location_input"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/pref_location"
            android:hint="Choose Location">

            <AutoCompleteTextView
                android:id="@+id/locationDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:boxBackgroundColor="#F5F5F5"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- DOB -->
        <TextView
            android:id="@+id/DOBinput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/pref_location_input"
            android:layout_marginTop="20dp"
            android:text="Date of Birth"
            android:textStyle="bold"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/text_input_DOB"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/DOBinput"
            android:hint="MM / DD / YYYY">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dobEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:boxBackgroundColor="#F5F5F5"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Salary Type Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/salaryTypeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_input_DOB"
            android:layout_marginTop="20dp"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:padding="16dp"
            app:boxBackgroundColor="#F5F5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/salaryTypeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salary Type"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginEnd="10dp"/>

                <RadioGroup
                    android:id="@+id/salaryTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp">

                    <RadioButton
                        android:id="@+id/radioHour"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Per Hour"/>

                    <RadioButton
                        android:id="@+id/radioDay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Per Day"/>

                    <RadioButton
                        android:id="@+id/radioWeek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Per Week"/>

                    <RadioButton
                        android:id="@+id/radioMonth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Per Month"/>

                    <RadioButton
                        android:id="@+id/radioProject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Per Project"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Salary Range Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/salaryRangeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/salaryTypeCard"
            android:layout_marginTop="20dp"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/salaryRangeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salary Range"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <RadioGroup
                    android:id="@+id/salaryRangeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/savebtn"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/salaryRangeCard"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="Save"
            app:backgroundTint="#0D47A1"
            app:cornerRadius="12dp"/>
    </RelativeLayout>
</ScrollView>